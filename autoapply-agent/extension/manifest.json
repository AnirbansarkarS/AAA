{
  "manifest_version": 3,
  "name": "AutoApply Agent",
  "version": "1.0",
  "description": "Automated AI-assisted job application agent",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
