{
  "manifest_version": 3,
  "name": "AutoApply Agent",
  "version": "1.1",
  "description": "Automated AI-assisted job application agent",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://*.linkedin.com/*",
    "https://api.github.com/*",
    "https://api.elevenlabs.io/*",
    "https://api.tavily.com/*",
    "https://api.ocr.space/*",
    "https://www.filestackapi.com/*",
    "https://cdn.filestackcontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        ".env"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    },
    {
      "matches": [
        "https://*.linkedin.com/in/*"
      ],
      "js": [
        "linkedin-scraper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
